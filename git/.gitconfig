[init]
    defaultBranch = main

[core]
    ignorecase = false
    quotepath = false

[i18n]
    commitEncoding = utf-8
    logOutputEncoding = utf-8

# 引入本地定制配置（如用户名、邮箱等私密/差异化信息）
# 该文件由 bootstrap.sh 交互式引导创建，且建议不纳入版本控制以防隐私泄露
[include]
    path = ~/.gitconfig.local

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
